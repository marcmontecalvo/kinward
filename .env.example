KINWARD_ENVIRONMENT=development
KINWARD_API_PORT=8000
KINWARD_DATABASE_URL=sqlite+aiosqlite:////data/kinward.db
# Required only for first-run setup. Generate a random value (at least 24 characters),
# supply it through the process environment, and remove it after setup completes.
# KINWARD_SETUP_AUTHORIZATION is intentionally omitted.

# Optional providers. Configuration does not claim capability availability.
KINWARD_MODEL_PROVIDER=none
KINWARD_MEMORY_BACKEND=none
KINWARD_HONCHO_URL=
KINWARD_KNOWLEDGE_BACKEND=none
KINWARD_LLM_WIKI_URL=
KINWARD_CALENDAR_PROVIDER=none

# Optional Home Assistant integration.
KINWARD_HOME_ASSISTANT_URL=
KINWARD_HOME_ASSISTANT_TOKEN=

# Optional direct Google/Microsoft calendar account connections (Epic 5 v1 roadmap).
# Off-script per product owner: this is the one Kinward-owned webpage in the
# system, served at {KINWARD_OAUTH_REDIRECT_BASE_URL}/setup/accounts, since
# connecting an account requires a real browser redirect to the provider's
# consent screen and back - no Home Assistant card or service call can do that.
# Leave a provider's client id/secret unset to leave it disabled; each provider
# only becomes usable once its client credentials, the redirect base URL, and
# the token encryption key below are all set.
KINWARD_GOOGLE_CLIENT_ID=
KINWARD_GOOGLE_CLIENT_SECRET=
KINWARD_MICROSOFT_CLIENT_ID=
KINWARD_MICROSOFT_CLIENT_SECRET=
KINWARD_MICROSOFT_TENANT=common
# The externally reachable base URL Kinward itself is served at (no trailing
# slash) - used to build each provider's OAuth redirect_uri. Must exactly match
# a redirect URI registered with the provider.
KINWARD_OAUTH_REDIRECT_BASE_URL=
# Fernet key used to encrypt stored Google/Microsoft tokens at rest. Generate one
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KINWARD_ACCOUNT_TOKEN_ENCRYPTION_KEY is intentionally omitted.
# A long-lived shared secret (at least 24 characters) required to view/use the
# /setup/accounts page and its API. Generate a random value and keep it private -
# unlike KINWARD_SETUP_AUTHORIZATION, this one is not single-use and is not
# removed after setup.
# KINWARD_ACCOUNTS_SETUP_TOKEN is intentionally omitted.

# Optional PostgreSQL profile. Supply the password only in the process environment.
POSTGRES_DB=kinward
POSTGRES_USER=kinward
# KINWARD_POSTGRES_PASSWORD is intentionally omitted.
