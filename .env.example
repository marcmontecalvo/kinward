KINWARD_ENVIRONMENT=development
KINWARD_API_PORT=8000
KINWARD_DATABASE_URL=sqlite+aiosqlite:///./kinward.db

# Optional memory and knowledge peers. Kinward boots without them.
KINWARD_MEMORY_BACKEND=none
KINWARD_HONCHO_URL=
KINWARD_KNOWLEDGE_BACKEND=none
KINWARD_LLM_WIKI_URL=

# Optional Home Assistant integration.
KINWARD_HOME_ASSISTANT_URL=
KINWARD_HOME_ASSISTANT_TOKEN=

# Optional PostgreSQL/Redis data profile. Replace before any non-local deployment.
POSTGRES_DB=kinward
POSTGRES_USER=kinward
POSTGRES_PASSWORD=change-me
