{
  "name": "@kinward/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "lint": "tsc --noEmit && eslint . && stylelint \"src/**/*.css\" && vitest run src/design-system --reporter=dot",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@kinward/schemas": "workspace:*",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.25.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9.19.0",
    "postcss": "^8.5.1",
    "stylelint": "^16.13.2",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
